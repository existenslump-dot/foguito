# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# --- CRÍTICO: SEGURIDAD Y LLAVES ---
# Ignoramos explícitamente todos los archivos que contienen credenciales de Supabase y Cloudinary
.env
.env.local
.env.development.local
.env.test.local
.env.production.local
.env*.local

# --- DEPENDENCIAS ---
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# --- NEXT.JS / BUILD ---
/.next/
/out/
/build
*.tsbuildinfo
next-env.d.ts

# --- TESTING ---
/coverage

# --- MISC / OS ---
.DS_Store
*.pem
*.key
*.lnk
Thumbs.db

# --- SUPABASE CLI (local link state: project-ref, pooler URL) ---
supabase/.temp/

# --- LOGS / DEBUG ---
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# --- VERCEL ---
.vercel

# --- IDEs (Opcional pero recomendado) ---
.vscode/
.idea/

# --- WORKSPACE PACKAGES BUILD OUTPUT ---
packages/*/dist/

# --- Claude Code harness worktrees ---
.claude/worktrees/
