# ═══════════════════════════════════════════════════════════════════════════
#  FOGUITO · Variables de entorno
#  Base = marketplace-starter (engine config-driven). Los nombres de las vars
#  del bloque BASE respetan el engine; el bloque FOGUITO agrega la capa de
#  compliance + pagos MoR/payout que el engine no trae.
#  Copiar a .env.local. NUNCA commitear secretos. Los NEXT_PUBLIC_* van al browser.
#  [PR] = en qué PR del roadmap se necesita.
# ═══════════════════════════════════════════════════════════════════════════

# ╔═══════════════════════════════════════════════════════════════════════════
# ║ BASE — heredado del engine (marketplace-starter)
# ╚═══════════════════════════════════════════════════════════════════════════

# ── Marca & dominio ───────────────────────────────────────────── [PR-0]
NEXT_PUBLIC_SITE_NAME=Foguito
NEXT_PUBLIC_SITE_DOMAIN=foguito.com
NEXT_PUBLIC_APP_URL=https://foguito.com
APP_URL_ALIASES=

# ── Mercado (el age-gate por jurisdicción se apoya acá) ───────── [PR-0/4]
MARKET_COUNTRY=BR,CL,AR                    # jurisdicciones del viewer (multi-país)
MARKET_COUNTRY_SLUG=brasil
MARKET_CURRENCY=USD
MARKET_LOCALE=es
MARKET_LOCALES=es,pt
NEXT_PUBLIC_COUNTRY_SLUG=brasil
NEXT_PUBLIC_MARKET_CURRENCY=USD
NEXT_PUBLIC_MARKET_LOCALE=es
MARKETPLACE_VERTICAL=creators              # foguito: creadoras+contenido, no "listings"

# ── Feature flags del engine ──────────────────────────────────── [PR-0]
FEATURE_KYC=true                           # ON: verificación de creadora (Didit) obligatoria
FEATURE_GEO_BLOCK=false
FEATURE_PAYMENTS=false                     # el engine trae MercadoPago; foguito usa su propio riel MoR (abajo)
NEXT_PUBLIC_PAYMENTS_ENABLED=false
FEATURE_CREDITS=true                       # base del crédito interno "foguitos" (se refuerza a ledger doble entrada en PR-6)
# FEATURE_STORIES / FEATURE_REVIEWS / FEATURE_BLOG: off (no aplican a foguito)

# ── Verificación / KYC creadora — Didit (YA implementado en el engine) ── [PR-1]
KYC_PROVIDER=didit                         # 'manual' = fallback admin; 'didit' = hosted 18+
DIDIT_API_KEY=                             # SECRET — header x-api-key
DIDIT_WORKFLOW_ID=                         # workflow: doc gov + liveness + face match
DIDIT_WEBHOOK_SECRET=                      # SECRET — HMAC del webhook
DIDIT_PAYLOAD_KEY=                         # SECRET — AES-256 (32 bytes) `openssl rand -hex 32`. Reusar patrón para cifrar 2257

# ── Supabase (auth, DB, storage, RLS) ─────────────────────────── [PR-0]
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=                 # SECRET
SUPABASE_PROJECT_ID=                       # para types:generate

# ── Media (Cloudinary) — el watermark ya existe en el engine ──── [PR-5]
NEXT_PUBLIC_CLOUDINARY_CLOUD=
NEXT_PUBLIC_CLOUDINARY_PRESET=             # ⚠️ contenido pagado NO va por preset unsigned → firmar (PR-5)
NEXT_PUBLIC_CLOUDINARY_WATERMARK_ID=       # overlay de watermark
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=                     # SECRET — firma server-side de URLs de entrega

# ── Captcha (Turnstile, bound al hostname de prod) ────────────── [PR-0]
NEXT_PUBLIC_TURNSTILE_SITE_KEY=
TURNSTILE_SECRET=                          # SECRET

# ── Rate limiting (Upstash) · Email (Resend) · Admin/Cron ─────── [PR-0]
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=                  # SECRET
RESEND_API_KEY=                            # SECRET
EMAIL_FROM=                                # "Foguito <noreply@foguito.com>"
ADMIN_EMAIL=
ADMIN_SECRET=                              # SECRET — lane de endpoints admin (≠ claves de cifrado)
CRON_SECRET=                               # SECRET — auth de /api/cron/*
IDENTITY_RETENTION_DAYS=365                # minimización PII (KYC/age-gate) tras cierre de cuenta

# ── Observabilidad (Sentry) ───────────────────────────────────── [PR-10]
NEXT_PUBLIC_SENTRY_DSN=
SENTRY_AUTH_TOKEN=                         # SECRET

# ╔═══════════════════════════════════════════════════════════════════════════
# ║ FOGUITO — NUEVO (no viene en el engine)
# ╚═══════════════════════════════════════════════════════════════════════════

# ── Age-gate del consumidor (verificación real, no checkbox) ──── [PR-4]
# Sigue la jurisdicción del viewer. Brasil (ECA Digital 2026), 25+ estados US, UK, EU.
NEXT_PUBLIC_AGE_VERIFY_PROVIDER=           # ej: didit | yoti | incode
AGE_VERIFY_API_KEY=                        # SECRET
AGE_VERIFY_WEBHOOK_SECRET=                 # SECRET

# ── Detección de CSAM (bloqueante, pre-publicación) ───────────── [PR-3]
# Vendor establecido — NO se construye desde cero (Thorn Safer / PhotoDNA / IWF).
CSAM_VENDOR=                               # ej: thorn-safer | photodna
CSAM_API_KEY=                              # SECRET
CSAM_WEBHOOK_SECRET=                       # SECRET
NCMEC_REPORT_API_KEY=                      # SECRET — CyberTipline (reporte obligatorio)
NCMEC_REPORT_ORG_ID=

# ── Pagos INBOUND (fan → plataforma) · MoR, PAN cero ──────────── [PR-7]
# Reemplaza el payments-kit MercadoPago del engine. Multi-procesador desde día 1.
CCBILL_CLIENT_ACCOUNT=
CCBILL_DATALINK_USER=
CCBILL_DATALINK_PASS=                      # SECRET
CCBILL_SALT=                               # SECRET — verificación de webhook
SEGPAY_PACKAGE_ID=
SEGPAY_API_KEY=                            # SECRET
# On-ramp card → USDT licenciado (el cargo figura como compra de cripto)
ONRAMP_PROVIDER=                           # ej: transak | moonpay (licenciado MoR)
ONRAMP_API_KEY=                            # SECRET
ONRAMP_WEBHOOK_SECRET=                     # SECRET

# ── Crédito de bucle cerrado (foguitos) + ledger doble entrada ── [PR-6]
# No redimible a efectivo/cripto, no transferible. Enforced en DB + app.
LEDGER_IDEMPOTENCY_SALT=                   # SECRET — idempotencia de asientos

# ── Payout REGULADO (plataforma → creadora) · la pata regulada ── [PR-8]
PAYOUT_PARTNER=                            # VASP/PSP licenciado
PAYOUT_API_KEY=                            # SECRET
PAYOUT_WEBHOOK_SECRET=                     # SECRET
TRAVEL_RULE_PROVIDER=                      # ej: notabene | trustline (FATF cripto)
TRAVEL_RULE_API_KEY=                       # SECRET

# ── AML / sanciones / PEP (las tres superficies) ──────────────── [PR-8/10]
SANCTIONS_SCREENING_PROVIDER=              # ej: complyadvantage | chainalysis
SANCTIONS_API_KEY=                         # SECRET

# ── Backups / DR (off-site cifrado, opt-in) ───────────────────── [PR-10]
BACKUP_ENCRYPTION_KEY=                     # SECRET — AES-256-GCM. GUARDAR SEPARADO de los backups
BACKUP_RETENTION=12
