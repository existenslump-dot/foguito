# ═══════════════════════════════════════════════════════════════════════════
#  FOGUITO · Variables de entorno
#  Copiar a .env.local. NUNCA commitear secretos. Los NEXT_PUBLIC_* viajan al
#  browser (no poner secretos ahí). El resto son server-only.
#  La columna [PR] indica en qué PR del roadmap se necesita cada bloque.
# ═══════════════════════════════════════════════════════════════════════════

# ── App / dominio ─────────────────────────────────────────────── [PR-0]
NEXT_PUBLIC_APP_URL=https://foguito.com
SELF_ORIGIN=https://foguito.com          # CSP img-src/connect-src del dominio propio
APP_URL_ALIASES=                          # orígenes extra same-origin (migración), coma-separado

# ── Supabase (auth, DB, storage, RLS) ─────────────────────────── [PR-0]
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=                # SECRET — solo server / crons / API admin
SUPABASE_PROJECT_ID=                      # para `npm run types:generate`

# ── OAuth (Google, implicit-flow) ─────────────────────────────── [PR-0]
NEXT_PUBLIC_OAUTH_STATE_CHECK=            # "on" para activar binding CSRF (probar en prod primero)

# ── Captcha (Cloudflare Turnstile, bound al hostname de prod) ──── [PR-0]
NEXT_PUBLIC_TURNSTILE_SITE_KEY=
TURNSTILE_SECRET=

# ── Identidad / KYC creadora — Didit (el moat 18+) ────────────── [PR-1]
# Verifica edad + identidad + screening. Sin verificación no hay onboarding.
DIDIT_API_KEY=                            # SECRET
DIDIT_WEBHOOK_SECRET=                     # SECRET — valida el callback del veredicto
DIDIT_WORKFLOW_ID=                        # flujo KYC (doc gov + liveness)
NEXT_PUBLIC_DIDIT_APP_ID=                 # si el widget corre client-side

# ── Age-gate del consumidor (verificación real por jurisdicción) ─ [PR-4]
# NO checkbox. Sigue la ubicación del viewer (no del servidor).
NEXT_PUBLIC_AGE_VERIFY_PROVIDER=          # ej: didit | yoti | incode
AGE_VERIFY_API_KEY=                       # SECRET
AGE_VERIFY_WEBHOOK_SECRET=                # SECRET
# Brasil (ECA Digital 2026), 25+ estados US, UK, EU → activar por región

# ── Detección de CSAM (bloqueante, pre-publicación) ───────────── [PR-3]
# Servicio establecido — NO se construye desde cero (PhotoDNA / Thorn Safer / IWF).
CSAM_VENDOR=                              # ej: thorn-safer | photodna
CSAM_API_KEY=                             # SECRET
CSAM_WEBHOOK_SECRET=                      # SECRET
# Reporte obligatorio a NCMEC CyberTipline ante hit / señal "posible menor"
NCMEC_REPORT_API_KEY=                     # SECRET
NCMEC_REPORT_ORG_ID=

# ── 2257 (registros de performers) ────────────────────────────── [PR-2]
# Sin env dedicada: se guarda en DB + storage privado con RLS. Clave de cifrado
# del custodio de records reusa BACKUP_ENCRYPTION_KEY / KYC bucket.

# ── Media: entrega de contenido (URLs firmadas + watermark) ───── [PR-5]
# Contenido pagado NO va por preset unsigned. Usar signed URLs + expiración.
# Opción A (imágenes + video corto): Cloudinary firmado
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=                    # SECRET — firma server-side
# Opción B (video largo / streaming con DRM): Mux o Bunny Stream
MUX_TOKEN_ID=
MUX_TOKEN_SECRET=                         # SECRET
MEDIA_SIGNING_KEY=                        # SECRET — firma de URLs de entrega + watermark

# ── Pagos INBOUND (fan → plataforma) · MoR, PAN cero ──────────── [PR-7]
# Adquirente high-risk especializado (multi-procesador desde el día 1).
CCBILL_CLIENT_ACCOUNT=
CCBILL_DATALINK_USER=
CCBILL_DATALINK_PASS=                     # SECRET
CCBILL_SALT=                              # SECRET — verificación de webhook
SEGPAY_PACKAGE_ID=
SEGPAY_API_KEY=                           # SECRET
# On-ramp card → USDT licenciado (el cargo figura como compra de cripto)
ONRAMP_PROVIDER=                          # ej: transak | moonpay (licenciado MoR)
ONRAMP_API_KEY=                           # SECRET
ONRAMP_WEBHOOK_SECRET=                    # SECRET

# ── Crédito interno (foguitos) + ledger doble entrada ─────────── [PR-6]
# No redimible a efectivo/cripto, no transferible. Enforced en DB + app.
LEDGER_IDEMPOTENCY_SALT=                  # SECRET — idempotencia de asientos

# ── Payout REGULADO (plataforma → creadora) · la pata regulada ── [PR-8]
# Revenue-share vía partner licenciado (VASP/PSP). Crypto USDT p/ LATAM.
PAYOUT_PARTNER=                           # ej: vasp/psp licenciado
PAYOUT_API_KEY=                           # SECRET
PAYOUT_WEBHOOK_SECRET=                    # SECRET
# Travel Rule (FATF) para cripto
TRAVEL_RULE_PROVIDER=                     # ej: notabene | trustline
TRAVEL_RULE_API_KEY=                      # SECRET

# ── AML / sanciones / PEP (las tres superficies) ──────────────── [PR-8/10]
SANCTIONS_SCREENING_PROVIDER=             # ej: complyadvantage | chainalysis
SANCTIONS_API_KEY=                        # SECRET

# ── Rate limiting (Upstash Redis; fallback en memoria si vacío) ─ [PR-0]
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=                 # SECRET

# ── Email transaccional (Resend) ──────────────────────────────── [PR-0]
RESEND_API_KEY=                           # SECRET

# ── Observabilidad (Sentry) ───────────────────────────────────── [PR-10]
NEXT_PUBLIC_SENTRY_DSN=
SENTRY_AUTH_TOKEN=                        # SECRET — source maps en build

# ── Crons (backups, expiración, healthcheck, screening batch) ─── [PR-0/10]
CRON_SECRET=                              # SECRET — auth de /api/cron/*

# ── Backups / DR (off-site cifrado, opt-in) ───────────────────── [PR-10]
BACKUP_ENCRYPTION_KEY=                    # SECRET — AES-256-GCM. GUARDAR SEPARADO de los backups
BACKUP_RETENTION=12
GDRIVE_REFRESH_TOKEN=                     # SECRET — réplica off-site (opcional)
GDRIVE_CLIENT_ID=
GDRIVE_CLIENT_SECRET=                     # SECRET
GDRIVE_BACKUP_FOLDER_NAME=Foguito Backups

# ── Endpoints admin (lane x-admin-secret) ─────────────────────── [PR-0]
ADMIN_SECRET=                             # SECRET — ≠ BACKUP_ENCRYPTION_KEY
